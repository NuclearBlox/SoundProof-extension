{
  "manifest_version": 3,
  "name": "Check SoulOverAI",
  "version": "1.0",
  "permissions": ["storage"],
  "icons": {
    "16": "Icons/Icon16.png",
    "48": "Icons/Icon48.png",
    "128": "Icons/Icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "Icons/*",
        "Utils/*"
      ],
      "matches": [
        "https://music.youtube.com/*",
        "https://music.apple.com/*",
        "https://open.spotify.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": [
        "Utils/Badge.js",
        "Utils/popUpHandling.js",
        "Utils/processCurrentSong.js",
        "Platforms/YtMusic.js"
      ]
    },
    {
      "matches": ["https://music.apple.com/*"],
      "js": [
        "Utils/Badge.js",
        "Utils/popUpHandling.js",
        "Utils/processCurrentSong.js",
        "Platforms/appleMusic.js"
      ]
    },
    {
      "matches": ["https://soundcloud.com/*"],
      "js": [
        "Utils/Badge.js",
        "Utils/popUpHandling.js",
        "Utils/processCurrentSong.js",
        "Platforms/soundcloud.js"
      ]
    },
    {
      "matches": ["https://open.spotify.com/*"],
      "js": [
        "Utils/Badge.js",
        "Utils/popUpHandling.js",
        "Utils/processCurrentSong.js",
        "Platforms/spotify.js"
      ]
    }
  ]
}
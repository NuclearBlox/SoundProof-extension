{
  "manifest_version": 3,
  "name": "Check SoulOverAI",
  "version": "1.0",
  "permissions": ["storage"],
  "web_accessible_resources": [{
    "resources": ["Icons/ArtistUsesAI.png", "Icons/LooksHuman.png", "Utils/Hover.html"],
    "matches": ["<all_urls>"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://music.youtube.com/*"],
    "js": ["Utils/Badge.js","Platforms/YtMusic.js"]
  },
  {
    "matches": ["https://music.apple.com/*"],
    "js": ["Utils/Badge.js","Platforms/appleMusic.js"]
  }]
}
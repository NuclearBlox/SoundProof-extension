{
  "manifest_version": 3,
  "name": "Detect & Skip AI Music - SoundProof",
  "version": "4.0.0",
  "permissions": ["storage"],
  "host_permissions": ["https://solsneywdlhvwbtghopw.supabase.co/*"],
  "icons": {
    "16": "Icons/Icon16.png",
    "48": "Icons/Icon48.png",
    "128": "Icons/Icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://music.youtube.com/*",
        "https://music.apple.com/*",
        "https://soundcloud.com/*",
        "https://open.spotify.com/*"
      ],
      "js": [
        "libs/supabase.js",
        "Utils/Badge.js",
        "Utils/popUpHandling.js",
        "Utils/processCurrentSong.js",
        "Platforms/YtMusic.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "Icons/*.png",
        "Badges/*.png",
        "Utils/*.js",
        "warning.html"
      ],
      "matches": [
        "https://music.youtube.com/*",
        "https://music.apple.com/*",
        "https://soundcloud.com/*",
        "https://open.spotify.com/*"
      ]
    }
  ]
}